{
  "name": "supreme-delivery-backend",
  "version": "1.0.0",
  "description": "Backend API for international package delivery and tracking",
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "db:migrate": "ts-node src/db/migrations/run.ts",
    "db:seed": "ts-node src/db/seeds/run.ts",
    "db:reset": "ts-node src/db/reset.ts",
    "db:generate": "prisma generate",
    "generate-api-docs": "ts-node src/utils/swagger.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "express-async-errors": "^3.1.0",
    "cors": "^2.8.0",
    "helmet": "^7.0.0",
    "compression": "^1.7.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.0",
    "typescript": "^5.0.0",
    "pg": "^8.10.0",
    "prisma": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "mongoose": "^7.2.0",
    "redis": "^4.6.0",
    "ioredis": "^5.3.0",
    "amqplib": "^0.10.0",
    "socket.io": "^4.7.0",
    "jsonwebtoken": "^9.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.0",
    "axios": "^1.4.0",
    "express-validator": "^7.0.0",
    "joi": "^17.9.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.0",
    "zod": "^3.21.0",
    "multer": "^1.4.0",
    "@aws-sdk/client-s3": "^3.350.0",
    "stripe": "^12.7.0",
    "nodemailer": "^6.9.0",
    "@types/nodemailer": "^6.4.0",
    "twilio": "^3.82.0",
    "mapbox-gl": "^2.15.0",
    "geolocation-utils": "^1.2.0",
    "turf": "^6.5.0",
    "@turf/turf": "^6.5.0",
    "bull": "^4.11.0",
    "node-cron": "^3.0.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.0",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "rate-limiter-flexible": "^2.4.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-oauth2": "^1.7.0",
    "@sentry/node": "^7.59.0",
    "uuid": "^9.0.0",
    "p-queue": "^7.3.0",
    "lodash": "^4.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/compression": "^1.7.0",
    "@types/morgan": "^1.9.0",
    "@types/jest": "^29.5.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.44.0",
    "typescript-eslint": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
