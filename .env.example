# Supreme Delivery - Environment Variables

# Application
NODE_ENV=development
APP_NAME=supreme-delivery
APP_PORT=5000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supreme_delivery
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# MongoDB (for real-time data)
MONGODB_URI=mongodb://localhost:27017/supreme-delivery

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=30d

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@supremedelivery.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Maps & Geolocation
MAPBOX_API_KEY=your-mapbox-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Payment Processing (Stripe)
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Carrier APIs
DHL_API_KEY=your-dhl-api-key
FEDEX_API_KEY=your-fedex-api-key
UPS_API_KEY=your-ups-api-key

# AWS (for file uploads, S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=supreme-delivery-bucket

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Socket.io
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OAuth (GitHub, Google, etc.)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Analytics
SENTRY_DSN=your-sentry-dsn
ANALYTICS_API_KEY=your-analytics-key

# Feature Flags
ENABLE_AI_OPTIMIZATION=true
ENABLE_BLOCKCHAIN_VERIFICATION=false
ENABLE_AR_TRACKING=false
ENABLE_MULTI_CARRIER=true